---
// src/components/ResultBox.astro
interface Props {
  id: string;
  label: string;
}

const { id, label } = Astro.props;
---

<div
  id={`${id}-container`}
  class="hidden mt-6 p-6 bg-blue-600 rounded-2xl text-white shadow-lg shadow-blue-200"
>
  <p class="text-blue-100 text-sm font-bold uppercase tracking-wider">
    {label}
  </p>
  <div class="text-4xl font-black mt-1">
    <span id={id}>0</span>
  </div>
</div>
