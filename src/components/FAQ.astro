---
// src/components/FAQ.astro
import { dataFaqs } from "../data/faqs";

const pathname = Astro.url.pathname;
const id = pathname.split('/').filter(Boolean).pop() || "";
const info = dataFaqs[id];

// Si no hay FAQ para esta página, el componente se "apaga" solo
if (!info) return null;
---

<section class="max-w-4xl mx-auto px-4 mt-20 mb-20">
  <div class="h-px bg-slate-200 w-full mb-16"></div>
  
  <h2 class="text-3xl font-black text-slate-900 mb-8 text-center">Preguntas Frecuentes</h2>
  
  <div class="max-w-3xl mx-auto space-y-4">
    {info.faqs.map(faq => (
      <details class="group bg-white border border-slate-200 rounded-2xl p-6 transition-all hover:border-blue-200 shadow-sm">
        <summary class="flex items-center justify-between cursor-pointer list-none font-bold text-slate-800 text-lg">
          {faq.q}
          <span class="text-blue-600 transition group-open:rotate-180">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <p class="mt-4 text-slate-600 leading-relaxed">{faq.a}</p>
      </details>
    ))}
  </div>

  <div class="mt-12 flex flex-wrap justify-center gap-3">
    {info.relacionados.map(link => (
      <a href={link.link} class="text-sm font-bold text-blue-600 bg-blue-50 px-4 py-2 rounded-full hover:bg-blue-100 transition">
        {link.nombre}
      </a>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": info.faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
})}>
</script>