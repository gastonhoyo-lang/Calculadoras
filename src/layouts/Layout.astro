---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Calculadoras financieras gratuitas para tomar mejores decisiones.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Chieffin</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:type" content="website" />
 interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Calculadoras financieras gratuitas: Simulá préstamos, calculá interés compuesto y tomá mejores decisiones con Chieffin.",
} = Astro.props;

// Definimos la URL base para las imágenes y links
const canonicalURL = new URL(Astro.url.pathname, "https://chieffin.com");
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />

  <link rel="canonical" href={canonicalURL} />

  <title>{title} | Chieffin</title>
  <meta name="title" content={`${title} | Chieffin`} />
  <meta name="description" content={description} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://chieffin.com/og-image.jpg" />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content="https://chieffin.com/og-image.jpg" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
  
  <body class="bg-slate-50 text-slate-900 font-sans antialiase d">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <nav
        class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between"
      >
        <a href="/" class="text-2xl font-black tracking-tight text-blue-600">
          CHIEFFIN<span class="text-slate-400">.com</span>
        </a>

        <div class="hidden md:flex gap-6 text-sm font-medium text-slate-600">
          <div class="relative group">
            <button
              class="flex items-center gap-1 hover:text-blue-600 transition py-5 font-medium"
            >
              Finanzas
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-slate-400 group-hover:text-blue-600 transition"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div
              class="absolute left-0 mt-0 w-64 bg-white border border-slate-200 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible group-hover:mt-2 transition-all duration-200 z-[60]"
            >
              <div class="p-2">
                <a
                  href="/finanzas/prestamo"
                  class="block px-4 py-3 text-sm text-slate-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition"
                >
                  <span class="block font-bold">Simulador de Préstamos</span>
                  <span class="text-xs text-slate-500 italic"
                    >Calculá tus cuotas mensuales</span
                  >
                </a>
                <a
                  href="/finanzas/porcentaje"
                  class="block px-4 py-3 text-sm text-slate-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition border-t border-slate-50"
                >
                  <span class="block font-bold">Calculadora de Porcentajes</span
                  >
                  <span class="text-xs text-slate-500 italic"
                    >IVA, descuentos y aumentos</span
                  >
                </a>
              </div>
            </div>
          </div>

          <a
            href="/finanzas/interescompuesto"
            class="flex items-center hover:text-blue-600 transition py-5"
            >Inversiones</a
          >
          <a
            href="/finanzas/porcentaje"
            class="flex items-center hover:text-blue-600 transition py-5"
            >Impuestos</a
          >
        </div>

        <button
          class="bg-slate-900 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-slate-800 transition"
        >
          Favoritos
        </button>
      </nav>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-12 min-h-[calc(100vh-160px)]">
      <slot />
    </main>

    <footer class="bg-white border-t border-slate-200 py-12">
      <div
        class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm"
      >
        <div>
          <p class="font-bold text-lg mb-4">Chieffin</p>
          <p class="text-slate-500">
            Herramientas financieras diseñadas para ayudarte a entender mejor tu
            dinero.
          </p>
        </div>
        <div>
          <p class="font-bold mb-4">Categorías</p>
          <ul class="space-y-2 text-slate-500">
            <li>
              <a href="/finanzas/prestamo" class="hover:text-blue-600"
                >Préstamos Personales</a
              >
            </li>
            <li>
              <a href="/finanzas/interescompuesto" class="hover:text-blue-600"
                >Interés Compuesto</a
              >
            </li>
            <li>
              <a href="/finanzas/porcentaje" class="hover:text-blue-600"
                >Calculadora de IVA</a
              >
            </li>
          </ul>
        </div>
        <div>
          <p class="font-bold mb-4">Legal</p>
          <ul class="space-y-2 text-slate-500">
            <li>
              <a href="/privacidad" class="hover:text-blue-600">Privacidad</a>
            </li>
            <li>
              <a href="/contacto" class="hover:text-blue-600">Contacto</a>
            </li>
          </ul>
        </div>
      </div>
      <div
        class="max-w-6xl mx-auto px-4 mt-12 pt-8 border-t border-slate-100 text-center text-slate-400 text-xs"
      >
        &copy; {new Date().getFullYear()} Chieffin.com - Educación financiera sin
        complicaciones.
      </div>
    </footer>
  </body>
</html>
