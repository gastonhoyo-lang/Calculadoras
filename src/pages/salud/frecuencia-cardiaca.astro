---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Calculadora de Frecuencia Cardíaca Máxima"
  description="Calculá tu FC Máxima para entrenar en las zonas correctas de intensidad."
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div
      class="bg-white p-8 rounded-[3rem] shadow-sm border border-slate-50 max-w-md mx-auto text-center"
    >
      <h2 class="text-2xl font-black mb-6">
        Tu <span class="text-red-500">Corazón</span> ❤️
      </h2>
      <input
        type="number"
        id="edadFC"
        placeholder="Tu edad"
        class="w-full p-4 bg-slate-50 rounded-2xl mb-6 outline-none font-bold text-center text-xl border-2 border-transparent focus:border-red-500"
      />
      <button
        id="btnFC"
        class="w-full bg-red-600 text-white p-4 rounded-2xl font-bold hover:bg-red-700 transition-all"
        >Calcular FC Máx</button
      >

      <div id="resFC" class="hidden mt-8 space-y-2 animate-in fade-in zoom-in">
        <p class="text-slate-500 font-medium">Tu máximo estimado es:</p>
        <div class="text-5xl font-black text-slate-900">
          <span id="valFC"></span> PPM
        </div>
        <div class="mt-6 pt-4 border-t border-slate-100">
          <p
            class="text-[10px] text-slate-400 uppercase font-bold tracking-widest"
          >
            Fórmula de Tanaka
          </p>
          <p class="text-xs text-slate-500 font-mono">208 - (0.7 x edad)</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Usamos una función autoejecutada para aislar el scope
    (function () {
      const btn = document.getElementById("btnFC");
      btn?.addEventListener("click", () => {
        const input = document.getElementById("edadFC") as HTMLInputElement;
        const edadValor = parseFloat(input.value);
        if (edadValor > 0) {
          const fmax = 208 - 0.7 * edadValor;
          const display = document.getElementById("valFC");
          if (display) display.innerText = Math.round(fmax).toString();
          document.getElementById("resFC")?.classList.remove("hidden");
        }
      });
    })();
  </script>
</Layout>
