---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Calculadora de Calorías | TMB"
  description="Calculá cuántas calorías quema tu cuerpo en reposo (Tasa Metabólica Basal) y cuántas necesitás para mantener o perder peso."
>
  <div class="max-w-4xl mx-auto px-4">
    <header class="text-center mb-12">
      <h1 class="text-4xl font-black text-slate-900">
        Gasto <span class="text-orange-500">Calórico</span> 🔥
      </h1>
    </header>

    <div
      class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm space-y-4 max-w-md mx-auto"
    >
      <select
        id="sexoC"
        class="w-full p-4 bg-slate-50 rounded-2xl outline-none font-bold"
      >
        <option value="H">Hombre</option>
        <option value="M">Mujer</option>
      </select>
      <input
        type="number"
        id="pesoC"
        placeholder="Peso (kg)"
        class="w-full p-4 bg-slate-50 rounded-2xl outline-none font-bold"
      />
      <input
        type="number"
        id="alturaC"
        placeholder="Altura (cm)"
        class="w-full p-4 bg-slate-50 rounded-2xl outline-none font-bold"
      />
      <input
        type="number"
        id="edadC"
        placeholder="Edad"
        class="w-full p-4 bg-slate-50 rounded-2xl outline-none font-bold"
      />
      <button
        id="btnCal"
        class="w-full bg-slate-900 text-white p-5 rounded-2xl font-bold"
        >Calcular TMB</button
      >

      <div
        id="resCal"
        class="hidden p-6 bg-orange-50 rounded-3xl text-center border-2 border-orange-100"
      >
        <p class="text-orange-600 text-xs font-bold uppercase">
          Tu metabolismo basal es de:
        </p>
        <div class="text-3xl font-black text-orange-900">
          <span id="valCal"></span> kcal
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById("btnCal")?.addEventListener("click", () => {
      const s = (document.getElementById("sexoC") as HTMLSelectElement).value;
      const p = parseFloat(
        (document.getElementById("pesoC") as HTMLInputElement).value,
      );
      const a = parseFloat(
        (document.getElementById("alturaC") as HTMLInputElement).value,
      );
      const e = parseFloat(
        (document.getElementById("edadC") as HTMLInputElement).value,
      );

      if (p && a && e) {
        let tmb = 10 * p + 6.25 * a - 5 * e;
        tmb = s === "H" ? tmb + 5 : tmb - 161;

        document.getElementById("valCal")!.innerText =
          Math.round(tmb).toString();
        document.getElementById("resCal")?.classList.remove("hidden");
      }
    });
  </script>
</Layout>
