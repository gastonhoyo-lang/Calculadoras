---
export const prerender = false;
const { slug } = Astro.params;

// 1. LIMPIEZA TOTAL: Si la URL es "algo.html", nos quedamos solo con "algo"
const cleanSlug = slug
  ? slug
      .toString()
      .replace(/\.html$/, "")
      .replace(/\/$/, "")
      .split("/")
      .pop()
      .toLowerCase()
  : "";

const runtime = Astro.locals.runtime;

// 2. SEGURIDAD: Verificamos que el entorno exista
if (!runtime || !runtime.env || !runtime.env.CALCULADORAS) {
  return new Response(
    "Error: No se detecta el KV 'CALCULADORAS'. Revisa los Bindings.",
    { status: 500 },
  );
}

const { CALCULADORAS } = runtime.env;

// 3. BUSQUEDA: Usamos la llave limpia
const rawData = await CALCULADORAS.get(cleanSlug);

if (!rawData) {
  // Si falla, mostramos qué llave intentó buscar para debuguear
  return new Response(
    `Error 404: No existe la llave [${cleanSlug}] en el KV.`,
    { status: 404 },
  );
}

const info = JSON.parse(rawData);
---

<html>
  <head>
    <title>{info.titulo}</title>
  </head>
  <body>
    <h1>{info.titulo}</h1>
  </body>
</html>
