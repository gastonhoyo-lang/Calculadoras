---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";

// Reparación de Build: Eliminamos cualquier expresión que Astro confunda con JS.
---

<Layout
  title="Generador de Contraseñas Seguras Online | Crea Claves Fuertes"
  description="Crea contraseñas seguras y robustas con nuestro generador online. Personaliza longitud, símbolos y números para proteger tus cuentas contra ataques."
>
  <main class="max-w-5xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1
        class="text-4xl md:text-6xl font-black text-slate-900 mb-4 tracking-tight"
      >
        Generador de <span class="text-blue-600">Contraseñas Seguras</span> 🔐
      </h1>
      <p
        class="text-slate-500 text-lg font-medium max-w-2xl mx-auto text-balance"
      >
        Protege tu identidad digital creando claves imposibles de descifrar.
      </p>
    </header>

    <section
      class="bg-white p-8 md:p-12 rounded-[3rem] border border-slate-100 shadow-2xl max-w-3xl mx-auto mb-20"
    >
      <div class="space-y-8">
        <div class="relative group">
          <input
            type="text"
            id="outputPassword"
            readonly
            class="w-full p-6 bg-slate-900 text-blue-400 font-mono text-2xl rounded-2xl border-4 border-slate-800 text-center outline-none transition-all"
            value="Cargando..."
          />
          <button
            id="btnCopy"
            class="absolute right-4 top-1/2 -translate-y-1/2 bg-blue-600 text-white p-2 rounded-lg hover:bg-blue-700 transition-colors text-sm font-bold"
          >
            Copiar
          </button>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <label
              class="block text-xs font-bold text-slate-400 uppercase tracking-widest"
            >
              Longitud: <span id="lengthLabel" class="text-blue-600">16</span>
            </label>
            <input
              type="range"
              id="passLength"
              min="8"
              max="50"
              value="16"
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-600"
            />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <label
              class="flex items-center space-x-3 cursor-pointer p-3 bg-slate-50 rounded-xl"
            >
              <input
                type="checkbox"
                id="incUpper"
                checked
                class="w-5 h-5 accent-blue-600"
              />
              <span class="text-sm font-bold text-slate-700">A-Z</span>
            </label>
            <label
              class="flex items-center space-x-3 cursor-pointer p-3 bg-slate-50 rounded-xl"
            >
              <input
                type="checkbox"
                id="incLower"
                checked
                class="w-5 h-5 accent-blue-600"
              />
              <span class="text-sm font-bold text-slate-700">a-z</span>
            </label>
            <label
              class="flex items-center space-x-3 cursor-pointer p-3 bg-slate-50 rounded-xl"
            >
              <input
                type="checkbox"
                id="incNumber"
                checked
                class="w-5 h-5 accent-blue-600"
              />
              <span class="text-sm font-bold text-slate-700">0-9</span>
            </label>
            <label
              class="flex items-center space-x-3 cursor-pointer p-3 bg-slate-50 rounded-xl"
            >
              <input
                type="checkbox"
                id="incSymbol"
                checked
                class="w-5 h-5 accent-blue-600"
              />
              <span class="text-sm font-bold text-slate-700">!@#</span>
            </label>
          </div>
        </div>

        <button
          id="btnGenerate"
          class="w-full bg-slate-900 text-white p-5 rounded-2xl font-bold hover:bg-blue-600 transition-all shadow-lg active:scale-95 text-lg"
        >
          Generar Nueva Clave
        </button>
      </div>
    </section>

    <article
      class="prose prose-slate max-w-none border-t border-slate-200 pt-16 text-slate-700 font-light"
    >
      <h2 class="text-3xl font-black text-slate-900 mb-6 italic">
        La matemática de la seguridad digital
      </h2>

      <p class="mb-6">
        Para calcular la seguridad de una contraseña, los expertos utilizan la
        fórmula de combinaciones posibles, que se define matemáticamente como:
      </p>

      <div class="bg-slate-900 text-blue-400 p-8 rounded-3xl text-center mb-8">
        <p class="text-sm uppercase tracking-widest text-slate-400 mb-4">
          Fórmula de Entropía
        </p>
        <div class="text-3xl font-mono">Combinaciones = L^N</div>
      </div>

      <p class="mb-6">
        Donde <strong>L</strong> es el número de caracteres disponibles y <strong
          >N</strong
        > es la longitud de la clave. Al aumentar N (la longitud), la dificultad para
        un hacker crece de forma exponencial.
      </p>

      <h3 class="text-2xl font-bold text-slate-800 mb-4">
        Ejemplos de Robustez
      </h3>
      <ul class="space-y-4 mb-12">
        <li class="p-6 bg-slate-50 rounded-2xl border-l-4 border-blue-500">
          <strong>Clave de 8 caracteres:</strong> Vulnerable en minutos con fuerza
          bruta.
        </li>
        <li class="p-6 bg-slate-50 rounded-2xl border-l-4 border-blue-500">
          <strong>Clave de 16 caracteres:</strong> Requeriría miles de años para ser
          descifrada con tecnología actual.
        </li>
      </ul>
    </article>
  </main>

  <script>
    const initGen = () => {
      const out = document.getElementById("outputPassword") as HTMLInputElement;
      const btnG = document.getElementById("btnGenerate");
      const btnC = document.getElementById("btnCopy");
      const lenI = document.getElementById("passLength") as HTMLInputElement;
      const lenL = document.getElementById("lengthLabel");

      const sets = {
        u: "ABCDEFGHIJKLMNOPQRSTUVWXYZ",
        l: "abcdefghijklmnopqrstuvwxyz",
        n: "0123456789",
        s: "!@#$%^&*()_+~`|}{[]:;?><,./-=",
      };

      const gen = () => {
        const length = parseInt(lenI.value);
        let chars = "";
        if ((document.getElementById("incUpper") as HTMLInputElement).checked)
          chars += sets.u;
        if ((document.getElementById("incLower") as HTMLInputElement).checked)
          chars += sets.l;
        if ((document.getElementById("incNumber") as HTMLInputElement).checked)
          chars += sets.n;
        if ((document.getElementById("incSymbol") as HTMLInputElement).checked)
          chars += sets.s;

        if (chars === "") return (out.value = "Selecciona opciones");

        let p = "";
        for (let i = 0; i < length; i++) {
          p += chars.charAt(Math.floor(Math.random() * chars.length));
        }
        out.value = p;
      };

      lenI?.addEventListener("input", () => {
        if (lenL) lenL.innerText = lenI.value;
        gen();
      });

      btnG?.addEventListener("click", gen);
      btnC?.addEventListener("click", () => {
        navigator.clipboard.writeText(out.value);
        const t = btnC.innerText;
        btnC.innerText = "Copiado";
        setTimeout(() => (btnC.innerText = t), 2000);
      });

      gen();
    };
    initGen();
  </script>
</Layout>
