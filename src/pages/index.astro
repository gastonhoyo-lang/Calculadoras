---
import Layout from "../layouts/Layout.astro";
import { calculadoras } from "../data/calculadoras";
import unidades from "../data/unidades.json"; // <--- IMPORTANTE: Importamos el motor masivo
export const prerender = true;
const categorias = [
  {
    id: "finanzas",
    nombre: "Finanzas y Negocios",
    icon: "💰",
    color: "bg-emerald-50 text-emerald-700",
  },
  {
    id: "negocios",
    nombre: "Negocios y Emprendedores",
    icon: "📈",
    color: "bg-indigo-50 text-indigo-700",
  },
  {
    id: "hogar",
    nombre: "Hogar y Construcción",
    icon: "🏗️",
    color: "bg-slate-100 text-slate-700",
  },
  {
    id: "salud",
    nombre: "Salud y Bienestar",
    icon: "❤️",
    color: "bg-red-50 text-red-700",
  },
  {
    id: "utiles",
    nombre: "Herramientas Útiles",
    icon: "🛠️",
    color: "bg-blue-50 text-blue-700",
  },
  {
    id: "matematica",
    nombre: "Matemática y Geometría",
    icon: "📐",
    color: "bg-orange-50 text-orange-700",
  },
  {
    id: "seo",
    nombre: "SEO y Marketing",
    icon: "🚀",
    color: "bg-purple-50 text-purple-700",
  },
  {
    id: "unidades",
    nombre: "Conversores de Medida",
    icon: "↔️",
    color: "bg-amber-50 text-amber-700",
  },
];

// 1. Obtener calculadoras manuales
const getCalcsByCat = (cat: string) =>
  calculadoras.filter((c) => c.link.includes(`/${cat}/`));

// 2. Obtener una muestra representativa de las masivas (para no saturar la Home)
// Mostramos las 6 más importantes para que Google las rastree
const unidadesDestacadas = unidades.slice(0, 6);
---

<Layout
  title="Chieffin | Herramientas y Calculadoras Gratuitas Online"
  description="Más de 60,000 calculadoras y conversores gratuitos: Finanzas, Salud, Unidades y SEO. Rápidas, precisas y sin registro."
>
  <section class="bg-white pt-20 pb-16 border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1
        class="text-6xl md:text-8xl font-black text-slate-900 tracking-tight mb-6"
      >
        Herramientas que <br /><span class="text-indigo-600">simplifican</span> tu
        vida.
      </h1>
      <p class="text-slate-500 text-xl font-medium max-w-2xl mx-auto mb-10">
        Accede a nuestra red de <span class="text-slate-900 font-bold"
          >más de 60,000</span
        > herramientas de precisión. Gratis, instantáneo y diseñado para profesionales.
      </p>

      <div class="relative max-w-2xl mx-auto px-4">
        <input
          type="text"
          id="searchBox"
          placeholder="¿Qué necesitás calcular?"
          class="w-full p-6 pl-14 bg-white border-2 border-slate-200 rounded-2xl shadow-lg outline-none focus:border-indigo-500 text-lg transition-all"
        />
        <span class="absolute left-8 top-6 text-2xl text-slate-300">🔍</span>

        <div
          id="search-suggestions"
          class="absolute z-50 w-[calc(100%-2rem)] mt-2 bg-white rounded-xl shadow-2xl border border-slate-100 hidden"
        >
          <div id="suggestions-list" class="max-h-80 overflow-y-auto p-2"></div>
        </div>
      </div>
      // Tu script de búsqueda actual funciona perfecto, no hace falta cambiarlo.
      // Solo asegúrate de que el selector sea el correcto.
    </div>
    <script>
      // Importamos el JSON (Astro lo optimiza automáticamente)
      import unidades from "../data/unidades.json";

      const input = document.getElementById("searchBox");
      const suggestions = document.getElementById("search-suggestions");
      const list = document.getElementById("suggestions-list");
      const sections = document.querySelectorAll(".category-section");

      input.addEventListener("input", (e) => {
        const value = e.target.value.toLowerCase().trim();

        // 1. LÓGICA DE FILTRADO VISUAL (Categorías manuales)
        sections.forEach((section) => {
          const cards = section.querySelectorAll(".card-calc");
          let sectionVisible = false;

          cards.forEach((card) => {
            const keywords = card.getAttribute("data-keywords") || "";
            if (keywords.includes(value)) {
              card.style.display = "flex";
              sectionVisible = true;
            } else {
              card.style.display = "none";
            }
          });
          // Ocultamos la sección completa si no hay coincidencias
          section.style.display = sectionVisible ? "block" : "none";
        });

        // 2. LÓGICA DEL DESPLEGABLE (JSON masivo)
        if (value.length < 3) {
          suggestions.classList.add("hidden");
          return;
        }

        const matches = unidades
          .filter((u) => u.titulo.toLowerCase().includes(value))
          .slice(0, 8); // Solo mostramos los primeros 8

        if (matches.length > 0) {
          list.innerHTML = matches
            .map(
              (m) => `
        <a href="/utiles/${m.slug}" class="block p-4 hover:bg-indigo-50 text-left rounded-lg transition-colors border-b border-slate-50 last:border-0">
          <span class="font-bold text-slate-800">🧮 ${m.titulo}</span>
        </a>
      `,
            )
            .join("");
          suggestions.classList.remove("hidden");
        } else {
          suggestions.classList.add("hidden");
        }
      });

      // Cerrar al clickear fuera
      document.addEventListener("click", (e) => {
        if (!input.contains(e.target)) suggestions.classList.add("hidden");
      });
    </script>
  </section></Layout
>
