---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Calculadora de Edad Exacta | ¿Cuántos días viviste?"
  description="Descubrí tu edad exacta en años, meses, días y hasta segundos. Una herramienta divertida para conocer tu tiempo en el mundo."
>
  <div class="max-w-4xl mx-auto px-4">
    <header class="text-center mb-12">
      <h1
        class="text-4xl md:text-6xl font-black text-slate-900 tracking-tight mb-4"
      >
        Tu Tiempo en el <span class="text-emerald-500">Mundo</span>
      </h1>
      <p class="text-slate-500 text-lg font-medium">
        Ingresá tu fecha de nacimiento y sorprendete.
      </p>
    </header>

    <div class="max-w-md mx-auto mb-16">
      <div
        class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm space-y-6"
      >
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase mb-3"
            >Fecha de Nacimiento</label
          >
          <input
            type="date"
            id="fechaNac"
            class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-emerald-500 outline-none font-bold text-xl text-slate-700"
          />
        </div>
        <button
          id="btnEdad"
          class="w-full bg-emerald-500 text-white p-5 rounded-2xl font-bold hover:bg-emerald-600 transition-all shadow-lg shadow-emerald-100"
          >¡Descubrir!</button
        >
      </div>
    </div>

    <div
      id="resEdad"
      class="hidden grid grid-cols-2 md:grid-cols-4 gap-4 mb-20 animate-in zoom-in duration-500"
    >
      <div class="bg-white p-6 rounded-3xl border border-slate-100 text-center">
        <p class="text-slate-400 text-xs font-bold uppercase mb-1">Años</p>
        <span id="resAnios" class="text-3xl font-black text-emerald-600"></span>
      </div>
      <div class="bg-white p-6 rounded-3xl border border-slate-100 text-center">
        <p class="text-slate-400 text-xs font-bold uppercase mb-1">Meses</p>
        <span id="resMeses" class="text-3xl font-black text-emerald-600"></span>
      </div>
      <div class="bg-white p-6 rounded-3xl border border-slate-100 text-center">
        <p class="text-slate-400 text-xs font-bold uppercase mb-1">Días</p>
        <span id="resDias" class="text-3xl font-black text-emerald-600"></span>
      </div>
      <div class="bg-white p-6 rounded-3xl border border-slate-100 text-center">
        <p class="text-slate-400 text-xs font-bold uppercase mb-1">Horas</p>
        <span id="resHoras" class="text-3xl font-black text-emerald-600"></span>
      </div>
    </div>
  </div>

  <script>
    document.getElementById("btnEdad")?.addEventListener("click", () => {
      const fecha = (document.getElementById("fechaNac") as HTMLInputElement)
        .value;
      if (fecha) {
        const nac = new Date(fecha);
        const hoy = new Date();
        const diff = hoy.getTime() - nac.getTime();

        const anios = Math.floor(diff / (1000 * 60 * 60 * 24 * 365.25));
        const meses = Math.floor(diff / (1000 * 60 * 60 * 24 * 30.44));
        const dias = Math.floor(diff / (1000 * 60 * 60 * 24));
        const horas = Math.floor(diff / (1000 * 60 * 60));

        document.getElementById("resAnios")!.innerText = anios.toString();
        document.getElementById("resMeses")!.innerText = meses.toLocaleString();
        document.getElementById("resDias")!.innerText = dias.toLocaleString();
        document.getElementById("resHoras")!.innerText = horas.toLocaleString();

        document.getElementById("resEdad")?.classList.remove("hidden");
      }
    });
  </script>
</Layout>
