---
import Layout from "../../layouts/Layout.astro";
// Nota: Corregí la ruta del componente que tenía un ";" al final
import InputField from "../../components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout title="Simulador de Préstamo">
  <div class="max-w-2xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6 text-slate-800 tracking-tight">
      Simulador de Préstamo
    </h1>

    <div
      class="grid gap-4 bg-white p-6 rounded-2xl shadow-sm border border-slate-100"
    >
      <input
        type="number"
        id="monto"
        placeholder="Monto total ($)"
        class="p-4 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition"
      />
      <input
        type="number"
        id="cuotas"
        placeholder="Cantidad de cuotas (meses)"
        class="p-4 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition"
      />
      <input
        type="number"
        id="interes"
        placeholder="% Interés Anual (Ej: 45)"
        class="p-4 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition"
      />

      <button
        id="btnSimular"
        class="bg-indigo-600 text-white p-4 rounded-xl font-bold hover:bg-indigo-700 transition-all active:scale-95 shadow-lg shadow-indigo-100"
      >
        Simular Cuotas
      </button>

      <div
        id="resL"
        class="hidden p-8 bg-indigo-50 rounded-2xl border-2 border-indigo-100 text-center animate-in fade-in zoom-in duration-300"
      >
        <p
          class="text-indigo-600 font-medium mb-1 uppercase text-xs tracking-wider"
        >
          Tu cuota mensual estimada:
        </p>
        <h2
          id="cuotaVal"
          class="text-5xl font-black text-indigo-700 tracking-tighter"
        >
        </h2>
      </div>
    </div>
  </div>

  <script>
    // Esta función ahora vive dentro del script de Astro correctamente
    const calcular = () => {
      const m = parseFloat(
        (document.getElementById("monto") as HTMLInputElement).value,
      );
      const c = parseInt(
        (document.getElementById("cuotas") as HTMLInputElement).value,
      );
      const iAnual = parseFloat(
        (document.getElementById("interes") as HTMLInputElement).value,
      );

      if (m > 0 && c > 0 && iAnual > 0) {
        const iMensual = iAnual / 100 / 12;

        // Fórmula de cuota fija (Sistema Francés)
        const cuota = (m * iMensual) / (1 - Math.pow(1 + iMensual, -c));

        const cuotaFinal = document.getElementById("cuotaVal");
        const resultadoDiv = document.getElementById("resL");

        if (cuotaFinal && resultadoDiv) {
          cuotaFinal.innerText = new Intl.NumberFormat("es-AR", {
            style: "currency",
            currency: "ARS",
          }).format(cuota);

          resultadoDiv.classList.remove("hidden");
        }
      } else {
        alert("Por favor, completa todos los campos con números válidos.");
      }
    };

    // Conectamos el botón al hacer clic
    document.getElementById("btnSimular")?.addEventListener("click", calcular);
  </script>
</Layout>
