---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Calculadora de Inflación Acumulada"
  description="Calculá la inflación acumulada entre periodos."
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-black text-slate-900 mb-8 text-center">
      Inflación Acumulada
    </h1>

    <div class="grid md:grid-cols-2 gap-12">
      <div id="inputsContainer" class="space-y-4">
        <input
          type="number"
          step="any"
          class="inflation-input w-full p-4 border rounded"
          placeholder="Ej: 4.2"
        />
        <input
          type="number"
          step="any"
          class="inflation-input w-full p-4 border rounded"
          placeholder="Ej: 3.8"
        />
        <button id="addInput" class="w-full py-2 border-dashed border rounded"
          >+ Añadir periodo</button
        >
      </div>

      <div class="text-center p-6 bg-red-600 text-white rounded">
        <div id="resultOutput" class="text-5xl font-black">0%</div>
        <p id="calcStep">Calculando impacto...</p>
      </div>
    </div>
  </main>
</Layout>

<script client:load>
  const container = document.getElementById("inputsContainer");
  const addButton = document.getElementById("addInput");
  const output = document.getElementById("resultOutput");
  const step = document.getElementById("calcStep");

  function calculateAccumulated() {
    const inputs = document.querySelectorAll(".inflation-input");
    let totalMultiplier = 1;
    let hasValues = false;

    inputs.forEach((input) => {
      const val = parseFloat(input.value);
      if (!isNaN(val)) {
        totalMultiplier *= 1 + val / 100;
        hasValues = true;
      }
    });

    if (!hasValues) {
      if (output) output.innerText = "0%";
      return;
    }

    const totalInflation = (totalMultiplier - 1) * 100;
    if (output)
      output.innerText =
        totalInflation.toLocaleString(undefined, { maximumFractionDigits: 2 }) +
        "%";
    if (step) step.innerText = "Inflación compuesta calculada";
  }

  addButton?.addEventListener("click", () => {
    const newInput = document.createElement("input");
    newInput.type = "number";
    newInput.step = "any";
    newInput.placeholder = "Nuevo %";
    newInput.className = "inflation-input w-full p-4 border rounded";
    container?.appendChild(newInput);
    newInput.addEventListener("input", calculateAccumulated);
  });

  document
    .querySelectorAll(".inflation-input")
    .forEach((el) => el.addEventListener("input", calculateAccumulated));
</script>
