---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Conversor de Millas a Kilómetros | Precisión en Distancias"
  description="Calculadora online para convertir millas a kilómetros de forma exacta. Utiliza la tasa oficial de 1.60934 km por milla para tus viajes y proyectos."
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-black text-slate-900 mb-4 tracking-tight">
        Millas a Kilómetros
      </h1>
      <p class="text-slate-600 max-w-2xl mx-auto">
        Convertí unidades del sistema imperial al métrico con precisión decimal
        para navegación, deportes o viajes.
      </p>
    </div>

    <div
      class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100 mb-12"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <div class="space-y-4">
            <label
              class="block text-[10px] font-bold uppercase text-slate-400 ml-1 tracking-widest"
            >
              Distancia en Millas (mi)
            </label>
            <input
              type="number"
              id="milesInput"
              step="any"
              class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-blue-500 outline-none transition-all font-mono text-xl"
              placeholder="Ej: 10"
            />
          </div>

          <div class="flex items-center justify-center py-2">
            <div class="h-px bg-slate-100 flex-1"></div>
            <span
              class="px-4 text-slate-300 text-xs font-bold uppercase tracking-tighter"
              >Equivale a</span
            >
            <div class="h-px bg-slate-100 flex-1"></div>
          </div>

          <div class="space-y-4">
            <label
              class="block text-[10px] font-bold uppercase text-slate-400 ml-1 tracking-widest"
            >
              Distancia en Kilómetros (km)
            </label>
            <input
              type="number"
              id="kmInput"
              step="any"
              class="w-full p-4 bg-slate-50 rounded-2xl border-2 border-transparent focus:border-blue-500 outline-none transition-all font-mono text-xl"
              placeholder="Ej: 16.09"
            />
          </div>
        </div>

        <div
          class="text-center p-10 bg-blue-600 rounded-[2.5rem] shadow-lg shadow-blue-200 relative overflow-hidden h-full flex flex-col justify-center min-h-[300px]"
        >
          <div class="relative z-10 text-white">
            <span
              class="block text-[10px] font-bold uppercase opacity-80 mb-2 tracking-widest"
              >Resultado Visual</span
            >
            <div
              id="resultDisplay"
              class="text-6xl font-black leading-none break-all"
            >
              0 <small class="text-2xl opacity-60">km</small>
            </div>
            <p
              id="formulaHint"
              class="text-[10px] mt-6 font-bold uppercase tracking-widest bg-white/20 inline-block px-4 py-1 rounded-full italic"
            >
              1 mi = 1.60934 km
            </p>
          </div>
          <span
            class="absolute -right-4 -bottom-10 text-[12rem] font-black text-white/10 select-none"
            >KM</span
          >
        </div>
      </div>
    </div>

    <section
      class="prose prose-slate max-w-none border-t border-slate-100 pt-12 text-slate-700"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
        <div>
          <h2 class="text-3xl font-black text-slate-900 mb-6 tracking-tight">
            ¿Por qué la milla es diferente?
          </h2>
          <p>
            La <strong>milla internacional</strong> es una unidad de longitud que
            se utiliza principalmente en los Estados Unidos y el Reino Unido. Aunque
            el mundo se mueve mayoritariamente en kilómetros, la milla persiste en
            la señalización de carreteras y en la industria aeronáutica.
          </p>
          <p>
            Históricamente, la milla romana equivalía a mil pasos (<em
              >mille passus</em
            >), pero hoy está estandarizada bajo el acuerdo de 1959.
          </p>
        </div>

        <div
          class="bg-slate-900 p-8 rounded-[2rem] border border-slate-800 text-center flex flex-col justify-center shadow-2xl"
        >
          <h4
            class="text-blue-400 font-bold mb-4 uppercase tracking-widest text-xs"
          >
            Conversión Rápida
          </h4>
          <div class="space-y-4 font-mono">
            <p class="text-white">
              5 mi ≈ <span class="text-blue-400">8.05 km</span>
            </p>
            <p class="text-white">
              10 mi ≈ <span class="text-blue-400">16.09 km</span>
            </p>
            <p class="text-white">
              26.2 mi (Maratón) ≈ <span class="text-blue-400">42.19 km</span>
            </p>
          </div>
        </div>
      </div>

      <h3 class="text-2xl font-bold text-slate-900 mt-12 mb-8 text-center">
        Ejemplos de distancias comunes
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-200">
          <div class="text-3xl mb-4 text-center">🏁</div>
          <h4
            class="font-bold text-slate-900 mb-2 text-center text-sm uppercase italic"
          >
            Carreras
          </h4>
          <p class="text-xs leading-relaxed text-slate-600 text-center">
            Una carrera de <strong>5 millas</strong> equivale a <strong
              >8.04 kilómetros</strong
            >.
          </p>
        </div>

        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-200">
          <div class="text-3xl mb-4 text-center">✈️</div>
          <h4
            class="font-bold text-slate-900 mb-2 text-center text-sm uppercase italic"
          >
            Viajes
          </h4>
          <p class="text-xs leading-relaxed text-slate-600 text-center">
            La distancia entre Londres y Brighton es de unas <strong
              >50 millas</strong
            > (aprox. 80 km).
          </p>
        </div>

        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-200">
          <div class="text-3xl mb-4 text-center">🛰️</div>
          <h4
            class="font-bold text-slate-900 mb-2 text-center text-sm uppercase italic"
          >
            Espacio
          </h4>
          <p class="text-xs leading-relaxed text-slate-600 text-center">
            La línea de Kármán (el inicio del espacio) está a unas <strong
              >62 millas</strong
            > o 100 km.
          </p>
        </div>
      </div>

      <div
        class="p-8 bg-blue-50 rounded-[2rem] border border-blue-100 flex items-start gap-5 shadow-sm"
      >
        <div class="text-3xl bg-white p-3 rounded-2xl shadow-sm">📐</div>
        <div>
          <h4 class="text-blue-900 font-bold mb-1">Dato Matemático</h4>
          <p class="text-sm text-blue-800 leading-relaxed">
            ¿Sabías que la relación entre millas y kilómetros es muy cercana a
            la <strong>Sucesión de Fibonacci</strong>? 3 mi son casi 5 km, 5 mi
            son 8 km, y 8 mi son casi 13 km. ¡Es un truco mental excelente!
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const milesInput = document.getElementById(
    "milesInput",
  ) as HTMLInputElement | null;
  const kmInput = document.getElementById("kmInput") as HTMLInputElement | null;
  const resultDisplay = document.getElementById("resultDisplay");
  const FACTOR = 1.609344;

  const updateDisplay = (val: number) => {
    if (resultDisplay) {
      resultDisplay.innerHTML = `${val.toLocaleString(undefined, { maximumFractionDigits: 3 })} <small class="text-2xl opacity-60">km</small>`;
    }
  };

  milesInput?.addEventListener("input", () => {
    if (!kmInput) return;
    const miles = parseFloat(milesInput.value);
    if (!isNaN(miles)) {
      const km = miles * FACTOR;
      kmInput.value = Number.isInteger(km) ? km.toString() : km.toFixed(4);
      updateDisplay(km);
    } else {
      kmInput.value = "";
      updateDisplay(0);
    }
  });

  kmInput?.addEventListener("input", () => {
    if (!milesInput) return;
    const km = parseFloat(kmInput.value);
    if (!isNaN(km)) {
      const miles = km / FACTOR;
      milesInput.value = Number.isInteger(miles)
        ? miles.toString()
        : miles.toFixed(4);
      updateDisplay(km);
    } else {
      milesInput.value = "";
      updateDisplay(0);
    }
  });
</script>
