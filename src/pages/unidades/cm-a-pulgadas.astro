---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Conversor de cm a pulgadas | Herramienta Online"
  description="Convierte centímetros a pulgadas fácilmente con esta calculadora rápida y gratuita."
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-black text-slate-900 mb-6 text-center">
      Conversor de Centímetros a Pulgadas
    </h1>

    <div
      class="bg-white p-8 rounded-2xl shadow-xl border border-slate-100 max-w-md mx-auto"
    >
      <label class="block mb-2 font-bold text-slate-700">Centímetros (cm)</label
      >
      <input
        id="cmInput"
        type="number"
        placeholder="Ej: 100"
        class="w-full p-4 rounded-lg border border-slate-300 focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none"
      />

      <div class="mt-6 text-center">
        <span class="block text-slate-500 mb-1">Pulgadas (in)</span>
        <div id="inchesOutput" class="text-3xl font-bold text-cyan-700">0</div>
      </div>
    </div>
  </main>
</Layout>

<script client:load>
  const cmInput = document.getElementById("cmInput");
  const inchesOutput = document.getElementById("inchesOutput");

  cmInput?.addEventListener("input", () => {
    const cm = parseFloat(cmInput.value);

    if (isNaN(cm)) {
      inchesOutput.innerText = "0";
      return;
    }

    const inches = cm * 0.393701;
    inchesOutput.innerText = Number.isInteger(inches)
      ? inches.toString()
      : inches.toFixed(4);
  });
</script>
