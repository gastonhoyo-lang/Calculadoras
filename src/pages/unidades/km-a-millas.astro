---
import Layout from "../../layouts/Layout.astro";
import InputField from "/src/components/InputField.astro";
import ResultBox from "../../components/ResultBox.astro";
---

<Layout
  title="Conversor de Kilómetros a Millas | km a millas"
  description="Convertí kilómetros a millas de forma rápida y precisa. Ideal para viajes, mapas y distancias internacionales con nuestra calculadora bidireccional."
>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-black text-slate-900 mb-4 tracking-tight">
        Kilómetros a Millas
      </h1>
      <p class="text-slate-600 max-w-2xl mx-auto">
        Traducí distancias métricas al sistema imperial utilizado en EE.UU. y
        Reino Unido con precisión quirúrgica.
      </p>
    </div>

    <div
      class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100 mb-12"
    >
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-8 items-center"
      >
        <div class="space-y-2">
          <label
            class="block text-[10px] font-bold uppercase text-slate-400 ml-1 tracking-widest text-center"
          >
            Kilómetros (km)
          </label>
          <input
            type="number"
            id="kmInput"
            class="w-full p-6 bg-slate-50 rounded-3xl border-2 border-transparent focus:border-amber-500 outline-none transition-all font-mono text-3xl text-center"
            placeholder="1.60"
            step="any"
          />
        </div>

        <div class="flex justify-center">
          <div
            class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-amber-600 font-bold rotate-90 md:rotate-0 shadow-inner"
          >
            ⇄
          </div>
        </div>

        <div class="space-y-2">
          <label
            class="block text-[10px] font-bold uppercase text-slate-400 ml-1 tracking-widest text-center"
          >
            Millas (mi)
          </label>
          <input
            type="number"
            id="mileInput"
            class="w-full p-6 bg-slate-50 rounded-3xl border-2 border-transparent focus:border-amber-500 outline-none transition-all font-mono text-3xl text-center"
            placeholder="1"
            step="any"
          />
        </div>
      </div>

      <div
        class="mt-8 p-4 bg-amber-50 rounded-2xl text-center border border-amber-100"
      >
        <p id="infoText" class="text-amber-800 font-medium text-sm">
          Ingresá un valor para ver la conversión instantánea.
        </p>
      </div>
    </div>

    <section
      class="prose prose-slate max-w-none border-t border-slate-100 pt-12 text-slate-700"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
        <div>
          <h2 class="text-3xl font-black text-slate-900 mb-6 tracking-tight">
            Comprendiendo las Distancias
          </h2>
          <p>
            Mientras que casi todo el mundo utiliza el <strong
              >sistema métrico</strong
            > (kilómetros), países como Estados Unidos, Reino Unido y Liberia siguen
            utilizando la <strong>milla terrestre</strong> como unidad de medida principal
            para carreteras y mapas.
          </p>
          <p>
            Una milla terrestre equivale exactamente a <strong
              >1.609344 kilómetros</strong
            >. Nuestra calculadora utiliza este estándar internacional para
            garantizar que tus cálculos de viaje sean exactos.
          </p>
        </div>

        <div
          class="bg-slate-900 p-8 rounded-[2rem] shadow-2xl flex flex-col justify-center border border-slate-800"
        >
          <h4
            class="text-amber-400 font-bold mb-4 text-center uppercase tracking-widest text-xs"
          >
            Equivalencias de Velocidad
          </h4>
          <div class="space-y-3 text-white font-mono text-sm">
            <div class="flex justify-between border-b border-white/10 pb-1">
              <span class="opacity-60">60 km/h</span>
              <span>≈ 37.3 mph</span>
            </div>
            <div class="flex justify-between border-b border-white/10 pb-1">
              <span class="opacity-60">100 km/h</span>
              <span>≈ 62.1 mph</span>
            </div>
            <div class="flex justify-between border-b border-white/10 pb-1">
              <span class="opacity-60">120 km/h</span>
              <span>≈ 74.5 mph</span>
            </div>
          </div>
        </div>
      </div>

      <h3 class="text-2xl font-bold text-slate-900 mt-12 mb-8 text-center">
        Cuándo usar cada unidad
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-200">
          <div class="text-3xl mb-4 text-center">🚗</div>
          <h4
            class="font-bold text-slate-900 mb-2 text-center text-sm uppercase"
          >
            Road Trips
          </h4>
          <p class="text-xs leading-relaxed text-slate-600 text-center">
            Si vas a conducir en EE.UU., los límites de velocidad y las
            distancias en los carteles estarán siempre en <strong>millas</strong
            >.
          </p>
        </div>

        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-200">
          <div class="text-3xl mb-4 text-center">🏃</div>
          <h4
            class="font-bold text-slate-900 mb-2 text-center text-sm uppercase"
          >
            Atletismo
          </h4>
          <p class="text-xs leading-relaxed text-slate-600 text-center">
            Muchas carreras populares se miden en millas (como la famosa "Milla
            de Quinta Avenida") o en kilómetros (los 5K o 10K).
          </p>
        </div>

        <div class="p-6 bg-slate-50 rounded-3xl border border-slate-200">
          <div class="text-3xl mb-4 text-center">🚢</div>
          <h4
            class="font-bold text-slate-900 mb-2 text-center text-sm uppercase"
          >
            Navegación
          </h4>
          <p class="text-xs leading-relaxed text-slate-600 text-center">
            ¡Ojo! La <strong>milla náutica</strong> es distinta (1.852 km). Este conversor
            está diseñado para millas terrestres estándar.
          </p>
        </div>
      </div>

      <div
        class="p-8 bg-amber-50 rounded-[2rem] border border-amber-100 flex items-start gap-5 shadow-sm"
      >
        <div class="text-3xl bg-white p-3 rounded-2xl shadow-sm">💡</div>
        <div>
          <h4 class="text-amber-900 font-bold mb-1">Regla de cálculo rápido</h4>
          <p class="text-sm text-amber-800 leading-relaxed">
            ¿Sin calculadora? Una forma rápida de estimar es recordar que <strong
              >5 millas son 8 kilómetros</strong
            >. Dividí los km por 8 y multiplicalos por 5 para tener una idea
            aproximada.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const kmIn = document.getElementById("kmInput") as HTMLInputElement | null;
  const mileIn = document.getElementById(
    "mileInput",
  ) as HTMLInputElement | null;
  const info = document.getElementById("infoText");

  const FACTOR = 1.609344;

  const updateKm = () => {
    if (!kmIn || !mileIn) return;
    const km = parseFloat(kmIn.value);

    if (!isNaN(km)) {
      const miles = km / FACTOR;
      mileIn.value = Number.isInteger(miles)
        ? miles.toString()
        : miles.toFixed(2);
      if (info)
        info.innerText = `${km} kilómetros son aproximadamente ${mileIn.value} millas`;
    } else {
      mileIn.value = "";
      if (info) info.innerText = "Ingresá un valor para ver la conversión.";
    }
  };

  const updateMiles = () => {
    if (!kmIn || !mileIn) return;
    const miles = parseFloat(mileIn.value);

    if (!isNaN(miles)) {
      const km = miles * FACTOR;
      kmIn.value = Number.isInteger(km) ? km.toString() : km.toFixed(2);
      if (info)
        info.innerText = `${miles} millas equivalen a ${kmIn.value} kilómetros`;
    } else {
      kmIn.value = "";
      if (info) info.innerText = "Ingresá un valor para ver la conversión.";
    }
  };

  kmIn?.addEventListener("input", updateKm);
  mileIn?.addEventListener("input", updateMiles);
</script>
